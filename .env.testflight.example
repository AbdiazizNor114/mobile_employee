# Copy this file to .env.testflight and fill in production-safe public values.
# Do not commit .env.testflight.
#
# Required for TestFlight:
# - SHAQONET_API_BASE_URL must be an HTTPS URL reachable from real phones.
# - Supabase values must be public mobile-safe values only.

SHAQONET_API_BASE_URL=https://api.your-domain.com
SHAQONET_SUPABASE_URL=https://your-project.supabase.co
SHAQONET_SUPABASE_ANON_KEY=your-public-anon-key
